# ============================================
# AZUL - CONFIGURACIÓN BACKEND
# ============================================

# Store ID (ID de tu comercio en Azul)
# Sandbox: 39038540005
# Producción: Te lo proporciona Azul al afiliarte
AZUL_STORE_ID=39038540005

# Claves de autenticación
# Sandbox: testazul1 / testazul2
# Producción: Te las proporciona Azul
AZUL_AUTH1=testazul1
AZUL_AUTH2=testazul2

# Rutas a certificados SSL (proporcionados por Azul)
# Coloca los archivos .pem en la carpeta certs/
AZUL_CERT_PATH=./certs/azul_cert.pem
AZUL_KEY_PATH=./certs/ssl_key_cert.pem

# ============================================
# CONFIGURACIÓN GENERAL
# ============================================

# Puerto del servidor
PORT=3001

# URL del frontend (para CORS)
# Desarrollo: http://localhost:5173
# Producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:5173

# Teléfono de atención al cliente (aparece en transacciones)
CUSTOMER_SERVICE_PHONE=809-840-8257

# Entorno
# development = modo simulado sin certificados
# production = requiere certificados reales
NODE_ENV=development

# ============================================
# ENDPOINTS DE AZUL
# ============================================

# Sandbox (pruebas):
# https://pruebas.azul.com.do/webservices/JSON/Default.aspx

# Producción:
# https://pagos.azul.com.do/webservices/JSON/Default.aspx

# (El endpoint se configura en el código según NODE_ENV)

# ============================================
# INSTRUCCIONES
# ============================================

# 1. Copia este archivo y renómbralo a .env
# 2. Colócalo en la carpeta backend-azul/
# 3. Si tienes credenciales de Azul, reemplaza los valores de arriba
# 4. Si NO tienes credenciales aún, deja los valores de Sandbox
#    (el servidor funcionará en modo simulado)
# 5. NUNCA subas este archivo a GitHub
# 6. Los certificados .pem también deben estar en .gitignore

# ============================================
# CONTACTO AZUL PARA AFILIARTE
# ============================================

# Teléfono:  809-544-2985 (Afiliaciones)
#            809-544-6565 (Soporte técnico)
# Email:     solucionesecommerce@azul.com.do
# Web:       https://www.azul.com.do
# Portal:    https://dev.azul.com.do

# ============================================
# NOTAS IMPORTANTES
# ============================================

# - Los certificados SSL son OBLIGATORIOS en producción
# - En desarrollo sin certificados, el servidor simula respuestas
# - Nunca expongas Auth1/Auth2 en el frontend
# - Store ID puede ser visible, pero Auth1/Auth2 son secretas
# - Contacta a Azul si necesitas ayuda con la integración
