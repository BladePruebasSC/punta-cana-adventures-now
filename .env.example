# ============================================
# STRIPE - CONFIGURACIÓN DE PAGOS
# ============================================

# Clave pública de Stripe (va en el FRONTEND)
# Obtén esta clave en: https://dashboard.stripe.com/apikeys
# En modo test: pk_test_...
# En producción: pk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_aqui

# URL del backend para procesar pagos
# En desarrollo: http://localhost:3001
# En producción: https://tu-api.com
VITE_API_URL=http://localhost:3001

# ============================================
# SUPABASE
# ============================================

# URL de tu proyecto Supabase
VITE_SUPABASE_URL=tu_supabase_url

# Anon key de Supabase (clave pública)
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key

# ============================================
# INSTRUCCIONES
# ============================================

# 1. Copia este archivo y renómbralo a .env
# 2. Reemplaza los valores con tus claves reales
# 3. NUNCA subas el archivo .env a GitHub
# 4. Verifica que .env esté en .gitignore
